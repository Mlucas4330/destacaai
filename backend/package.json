{
  "name": "destacai-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch --env-file=.env src/index.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker.ts",
    "build": "tsc",
    "start:api": "node --env-file=.env dist/index.js",
    "start:worker": "node --env-file=.env dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/openai": "^3.0.52",
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "@hono/node-server": "^1.14.3",
    "@react-pdf/renderer": "^4.1.6",
    "ai": "^6.0.154",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.56.0",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.8.3",
    "ioredis": "^5.6.0",
    "jose": "^6.2.2",
    "pako": "^2.1.0",
    "pdfjs-dist": "^5.4.624",
    "postgres": "^3.4.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^17.7.0",
    "zod": "^3.24.4"
  },
  "overrides": {
    "@react-pdf/image": "3.0.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3"
  }
}
